{
  "name": "envcheck",
  "version": "0.1.0",
  "description": "Validate a project's .env against a contract so missing, extra, or empty variables are caught locally and in CI.",
  "type": "module",
  "bin": {
    "envcheck": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "env",
    "dotenv",
    "validation",
    "ci",
    "environment-variables",
    "cli"
  ],
  "author": "Abdulmunim Jemal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdulmunimjemal/envcheck.git"
  },
  "homepage": "https://oss.munim.io/envcheck/",
  "bugs": {
    "url": "https://github.com/abdulmunimjemal/envcheck/issues"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
